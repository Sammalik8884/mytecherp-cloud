{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/landing",   "dest": "/landing.html" },
    { "src": "/privacy",   "dest": "/privacy.html" },
    { "src": "/terms",     "dest": "/terms.html" },
    { "src": "/security",  "dest": "/security.html" },
    { "src": "/gdpr",      "dest": "/gdpr.html" },
    { "src": "/about",     "dest": "/about.html" },
    { "src": "/changelog", "dest": "/changelog.html" },
    { "src": "/roadmap",   "dest": "/roadmap.html" },
    { "src": "/careers",   "dest": "/careers.html" },
    { "src": "/blog",      "dest": "/blog.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
